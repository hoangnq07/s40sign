# Git Attributes for S40 Sign Tool
# Đảm bảo line endings đúng cho từng loại file

# Auto detect text files and normalize line endings to LF
* text=auto

# Shell scripts phải dùng LF (Linux/Mac)
*.sh text eol=lf

# Windows batch files phải dùng CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Python files dùng LF
*.py text eol=lf

# Markdown files
*.md text eol=lf

# Config files
*.json text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.jar binary
*.jks binary
*.keystore binary
*.p12 binary
*.cer binary
*.crt binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
